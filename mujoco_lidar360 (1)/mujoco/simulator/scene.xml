<mujoco model="g1_maze_scene">
  <include file="g1_29dof.xml"/>

  <statistic center="0 0 0.75" extent="8.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.22 0.22 0.22" rgb2="0.12 0.12 0.12"
             markrgb="0.7 0.7 0.7" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.15"/>
    <!-- Material de paredes: concreto gris claro, visible y reflejante para el LiDAR -->
    <material name="wall_mat" rgba="0.55 0.50 0.45 1" reflectance="0.05"/>
  </asset>

  <worldbody>
    <light pos="0 0 4"  dir="0 0 -1" directional="true" diffuse="0.7 0.7 0.7"/>
    <light pos="3 3 4"  dir="0 0 -1" directional="true" diffuse="0.3 0.3 0.3"/>
    <light pos="-3 -3 4" dir="0 0 -1" directional="true" diffuse="0.3 0.3 0.3"/>

    <!-- ============================================================ -->
    <!-- SUELO PLANO (group 3 → detectado por LiDAR)                  -->
    <!-- ============================================================ -->
    <geom name="floor"
          type="plane"
          size="0 0 0.05"
          material="groundplane"
          friction="2.5 2.5 2.5"
          group="3"/>

    <!-- ============================================================ -->
    <!-- PAREDES EXTERIORES DEL LABERINTO (10 m × 10 m)              -->
    <!-- Todas en group=3 para ser detectadas por el LiDAR            -->
    <!-- half-sizes: grosor=0.15, alto=0.75 (pared de 1.5 m)         -->
    <!-- ============================================================ -->

    <!-- Norte y sur: a lo largo de X -->
    <geom name="wall_north"
          type="box" pos="0 5 0.75" size="5.15 0.15 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>
    <geom name="wall_south"
          type="box" pos="0 -5 0.75" size="5.15 0.15 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>

    <!-- Este y oeste: a lo largo de Y -->
    <geom name="wall_east"
          type="box" pos="5 0 0.75" size="0.15 4.85 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>
    <geom name="wall_west"
          type="box" pos="-5 0 0.75" size="0.15 4.85 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>

    <!-- ============================================================ -->
    <!-- PAREDES INTERNAS DEL LABERINTO                               -->
    <!--                                                               -->
    <!--  Diseño (vista desde arriba, N arriba, robot en 0,0):        -->
    <!--                                                               -->
    <!--  +---+---+---+---+---+                                        -->
    <!--  |           |       |                                        -->
    <!--  |   +---+   |   +   |                                        -->
    <!--  |       |   |   |   |                                        -->
    <!--  |   R   +---+   |   |                                        -->
    <!--  |               |   |                                        -->
    <!--  |   +---+   +---+   |                                        -->
    <!--  |       |           |                                        -->
    <!--  +---+---+---+---+---+                                        -->
    <!--                                                               -->
    <!--  R = robot spawn (0,0)                                        -->
    <!--  Todos los corredores tienen 2 m de ancho (navegable G1)      -->
    <!-- ============================================================ -->

    <!-- Pared H1: horizontal en y=2, de x=-5 a x=-1 (gap al este) -->
    <geom name="wall_h1"
          type="box" pos="-3 2 0.75" size="2 0.15 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>

    <!-- Pared V1: vertical en x=-1, de y=2 a y=5 (conecta H1 con norte) -->
    <geom name="wall_v1"
          type="box" pos="-1 3.5 0.75" size="0.15 1.5 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>

    <!-- Pared H2: horizontal en y=2, de x=2 a x=5 (gap al oeste, junto a V1) -->
    <geom name="wall_h2"
          type="box" pos="3.5 2 0.75" size="1.5 0.15 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>

    <!-- Pared V2: vertical en x=2, de y=2 a y=5 (crea sala superior derecha) -->
    <geom name="wall_v2"
          type="box" pos="2 3.5 0.75" size="0.15 1.5 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>

    <!-- Pared H3: horizontal en y=-2, de x=1 a x=5 (gap al oeste) -->
    <geom name="wall_h3"
          type="box" pos="3 -2 0.75" size="2 0.15 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>

    <!-- Pared V3: vertical en x=1, de y=-5 a y=-2 (conecta H3 con sur) -->
    <geom name="wall_v3"
          type="box" pos="1 -3.5 0.75" size="0.15 1.5 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>

    <!-- Pared H4: horizontal en y=-2, de x=-5 a x=-2 (gap al este, sala inferior izda) -->
    <geom name="wall_h4"
          type="box" pos="-3.5 -2 0.75" size="1.5 0.15 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>

    <!-- Pared V4: vertical en x=-2, de y=-5 a y=-2 -->
    <geom name="wall_v4"
          type="box" pos="-2 -3.5 0.75" size="0.15 1.5 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>

    <!-- Pared H5: horizontal en y=0, de x=1 a x=3 (pared central) -->
    <geom name="wall_h5"
          type="box" pos="2 0 0.75" size="1 0.15 0.75"
          material="wall_mat" friction="1 0.05 0.01" group="3"/>

  </worldbody>
</mujoco>
